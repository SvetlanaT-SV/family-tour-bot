# ============================================================
# ШАБЛОН ФАЙЛА НАСТРОЕК — скопируй в .env и заполни значения
# НИКОГДА не отправляй .env в git!
# ============================================================

# --- Tourvisor ---
# Логин (email) от личного кабинета агентства на tourvisor.ru
TOURVISOR_LOGIN=your_login@email.ru
# Пароль от личного кабинета
TOURVISOR_PASSWORD=your_password

# --- Telegram ---
# Токен бота — получить у @BotFather командой /newbot
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ
# ID твоего канала или группы (например: @family_tour_ufa или -1001234567890)
TELEGRAM_CHANNEL_ID=@your_channel
# Твой личный Telegram ID — сюда будут приходить уведомления о заявках
# Узнать свой ID: написать боту @userinfobot
TELEGRAM_ADMIN_ID=123456789

# --- ВКонтакте ---
# Токен доступа к группе (получить: vk.com/dev → Мои приложения → ключ доступа группы)
VK_TOKEN=vk1.a.your_token_here
# ID группы (число, без минуса, например: 123456789 для vk.com/family_toor)
VK_GROUP_ID=123456789
# Логин и пароль от личного аккаунта VK (для автообновления токена загрузки фото)
# Если заданы — токен будет обновляться автоматически при истечении
VK_LOGIN=sv.trifonova@yandex.ru
VK_PASSWORD=Sve12ta34!!
# Токен пользователя (обновляется автоматически при наличии VK_LOGIN/VK_PASSWORD)
VK_USER_TOKEN=

# --- MAX (мессенджер от VK) ---
# Токен бота — получить у @PrimeBot в MAX командой /newbot
MAX_TOKEN=your_max_bot_token_here
# ID канала в MAX — узнать через GET https://platform-api.max.ru/chats с токеном
MAX_CHAT_ID=0

# --- Claude API (для генерации текстов) ---
# Получить на: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your_key_here

# --- Google Sheets (для базы клиентов) ---
# Путь к JSON-файлу сервисного аккаунта Google
GOOGLE_CREDENTIALS_FILE=google_credentials.json
# ID таблицы Google Sheets (из URL: docs.google.com/spreadsheets/d/ВОТ_ЭТО/edit)
GOOGLE_SHEET_ID=your_sheet_id_here

# --- Настройки фильтра туров ---
# Минимальная скидка в % (например: 20 = туры со скидкой от 20%)
MIN_DISCOUNT_PERCENT=20
# Максимальная цена за тур на двоих (в рублях)
MAX_PRICE=150000
# Количество дней вперёд для поиска вылетов
DAYS_AHEAD=14
# Минимальное количество ночей
NIGHTS_FROM=7
# Максимальное количество ночей
NIGHTS_TO=14
